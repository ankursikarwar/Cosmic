# W&B
WANDB_DIR=/path/to/wandb/cache
WANDB_CACHE_DIR=/path/to/wandb/cache
WANDB_ARTIFACT_DIR=/path/to/wandb/cache
WANDB_DATA_DIR=/path/to/wandb/cache
WANDB_CONFIG_DIR=/path/to/wandb/cache
WANDB_ENTITY=your_wandb_entity

# HuggingFace
HUGGINGFACE_HUB_TOKEN=your_huggingface_token

# API keys for proprietary models
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
CLAUDE_API_KEY=your_claude_api_key

# vLLM server endpoints (used by eval scripts)
ANSWERER_API_BASE=http://localhost:4877/v1
HELPER_API_BASE=http://localhost:4877/v1

# Data directory (path to benchmark parquet files)
DATA_DIR=./data

# Evaluation results directory
EVAL_DIR=./eval_results
